// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Profile {
  id             Int      @id @default(1)
  heightCm       Float
  weightKg       Float
  goalWeightKg   Float?
  age            Int
  sex            String
  activityLevel  String
  goal           String   @default("cut")
  kcalTarget     Int
  proteinG       Int
  carbG          Int
  fatG           Int
  waterMlTarget  Int
  lastMacroWeightKg Float?
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
}

model Recipe {
  id               Int            @id @default(autoincrement())
  title            String
  cuisine          String
  portions         Int
  kcalPerPortion   Int
  proteinG         Int
  carbG            Int
  fatG             Int
  batchStorageDays Int            @default(4)
  ingredients      Json
  steps            Json
  techniques       Json
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  plannedMeals     PlannedMeal[]
  cookSessions     CookSession[]
}

model MealPlan {
  id        Int           @id @default(autoincrement())
  weekStart DateTime      @unique
  notes     String?
  createdAt DateTime      @default(now())
  meals     PlannedMeal[]
}

model PlannedMeal {
  id                Int      @id @default(autoincrement())
  plan              MealPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  planId            Int
  day               Int
  slot              String
  recipe            Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId          Int
  portionsFromBatch Float    @default(1)
  locked            Boolean  @default(false)

  @@unique([planId, day, slot])
  @@index([recipeId])
}

model CookSession {
  id           Int      @id @default(autoincrement())
  date         DateTime
  recipe       Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId     Int
  portionsMade Int
  createdAt    DateTime @default(now())

  @@index([date])
}

model WaterEntry {
  id        Int      @id @default(autoincrement())
  day       DateTime
  ml        Int
  createdAt DateTime @default(now())

  @@index([day])
}

model WeightEntry {
  id        Int      @id @default(autoincrement())
  date      DateTime @unique
  kg        Float
  note      String?
  createdAt DateTime @default(now())

  @@index([date])
}
