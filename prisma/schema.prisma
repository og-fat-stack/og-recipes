// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  name         String
  /// Leer ("") = Konto ohne gesetztes Passwort: das beim ersten Login
  /// eingegebene Passwort wird gesetzt (Konto-Claim).
  passwordHash String   @default("")
  createdAt    DateTime @default(now())

  profile      Profile?
  claudeMemory ClaudeMemory?
  mealPlans    MealPlan[]
  expenses     WeeklyExpense[]
  weights      WeightEntry[]
  measurements MeasurementEntry[]
  steps        StepEntry[]
  dailyChecks  DailyCheck[]
  cookSessions CookSession[]
  recipes      Recipe[]
}

model Profile {
  id             Int      @id @default(autoincrement())
  // DB-Default 1 hält die noch deployte Single-User-Version während des
  // Migrationsfensters lauffähig (alles landet beim Alt-Konto).
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         Int      @unique @default(1)
  heightCm       Float
  weightKg       Float
  goalWeightKg   Float?
  age            Int
  sex            String
  activityLevel  String
  /// Training + Schritte in die Kalorienziele einrechnen? Aus = nur Grundbedarf
  /// (sedentary), die Extra-Aktivitätskalorien werden nicht gezählt.
  activityEnabled Boolean @default(true)
  goal           String   @default("cut")
  kcalTarget     Int
  proteinG       Int
  carbG          Int
  fatG           Int
  waterMlTarget  Int
  lastMacroWeightKg   Float?
  lastMacroBodyFatPct Float?
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
}

model ClaudeMemory {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int      @unique @default(1)
  content   String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Recipe {
  id               Int            @id @default(autoincrement())
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           Int            @default(1)
  title            String
  cuisine          String
  portions         Int
  kcalPerPortion   Int
  proteinG         Int
  carbG            Int
  fatG             Int
  batchStorageDays Int            @default(4)
  ingredients      Json
  steps            Json
  techniques       Json
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  plannedMeals     PlannedMeal[]
  cookSessions     CookSession[]

  @@index([userId])
}

model MealPlan {
  id            Int                 @id @default(autoincrement())
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        Int                 @default(1)
  weekStart     DateTime
  notes         String?
  createdAt     DateTime            @default(now())
  meals         PlannedMeal[]
  shoppingState ShoppingItemState[]

  @@unique([userId, weekStart])
}

model WeeklyExpense {
  id          Int      @id @default(autoincrement())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      Int      @default(1)
  weekStart   DateTime
  amountCents Int
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, weekStart])
}

model ShoppingItemState {
  id      Int      @id @default(autoincrement())
  plan    MealPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  planId  Int
  itemKey String
  checked Boolean  @default(false)

  @@unique([planId, itemKey])
}

model PlannedMeal {
  id                Int      @id @default(autoincrement())
  plan              MealPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  planId            Int
  day               Int
  slot              String
  recipe            Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId          Int
  portionsFromBatch Float    @default(1)
  locked            Boolean  @default(false)

  @@unique([planId, day, slot])
  @@index([recipeId])
}

model CookSession {
  id           Int         @id @default(autoincrement())
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       Int         @default(1)
  date         DateTime
  recipe       Recipe      @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId     Int
  portionsMade Int
  createdAt    DateTime    @default(now())

  @@index([date])
  @@index([userId])
}

model WeightEntry {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int      @default(1)
  date      DateTime
  kg        Float
  note      String?
  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@index([date])
}

model MeasurementEntry {
  id         Int      @id @default(autoincrement())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     Int      @default(1)
  date       DateTime
  waistCm    Float?
  hipCm      Float?
  bodyFatPct Float?
  note       String?
  createdAt  DateTime @default(now())

  @@unique([userId, date])
  @@index([date])
}

model StepEntry {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int      @default(1)
  date      DateTime
  steps     Int
  note      String?
  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@index([date])
}

model DailyCheck {
  id      Int      @id @default(autoincrement())
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId  Int      @default(1)
  date    DateTime
  itemKey String
  checked Boolean  @default(false)

  @@unique([userId, date, itemKey])
  @@index([date])
}
